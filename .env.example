# Site configuration
SITE_URL=https://orabthic.com
NEXT_PUBLIC_SITE_URL=https://orabthic.com

# Contact form — Resend email delivery (optional)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_FROM_EMAIL=noreply@orabthic.com
# CONTACT_TO_EMAIL=enterprise@orabthic.com

# Optional API key for contact endpoint (timing-safe header validation)
# CONTACT_API_SECRET=generate-a-long-random-secret-here

# Distributed rate limiting — Upstash Redis (recommended for production)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
